{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.bootstrap.rules",
      "firestore.indexes.json",
      ".firebaserc",
      ".firebaserc.example",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "PUBLISHING.md",
      "SECURITY_CHECKLIST.md",
      "TEST_REPORT.md",
      "validate_project.py",
      "firebase-firestore-rules-example.txt",
      "scripts/**",
      ".firebase_node20/**",
      "node_modules/**",
      ".git/**",
      ".github/**",
      "firebase-debug.log",
      "firestore-debug.log",
      "ui-debug.log",
      "*.zip",
      "*.ps1"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "assets/icons/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
